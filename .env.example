# Telegram BotFather 生成的 token
TELEGRAM_BOT_TOKEN=你的telegram_bot_token

# 来自 https://my.telegram.org 的 API ID / API HASH（给自建 telegram-bot-api 使用）
TELEGRAM_API_ID=你的telegram_api_id
TELEGRAM_API_HASH=你的telegram_api_hash

# 可选：上传目录（本地队列子目录），默认 TelegramVideos
ONEDRIVE_TARGET_DIR=TelegramVideos

# 可选：只允许某个聊天ID使用，不填则不限制
# ALLOWED_CHAT_ID=123456789

# OneDrive 网页登录账号（用于自动化上传）
ONEDRIVE_LOGIN_EMAIL=你的微软邮箱
ONEDRIVE_LOGIN_PASSWORD=你的微软密码

# 可选：OneDrive 网页入口
# ONEDRIVE_WEB_URL=https://onedrive.live.com

# 可选：扫描上传队列间隔（秒）
# ONEDRIVE_SCAN_INTERVAL_SECONDS=15

# 可选：是否无头模式（服务器建议 true）
# ONEDRIVE_HEADLESS=true
